OPENAI_API_KEY=
OPENROUTER_API_KEY=
AIOS_PUBLIC_URL=https://aios.bossayan.com
# Optional OpenAI-compatible chat-completions endpoint:
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Budget email notifications
RESEND_API_KEY=
AIOS_BILLING_FROM_EMAIL=AIOS Billing <billing@your-domain.com>

# Official OpenAI Responses API
AIOS_OPENAI_MODEL=gpt-5-mini
# Optional per-role override examples:
# AIOS_MODEL_ROUTER_AUTO=gpt-5-mini
# AIOS_MODEL_GPT_4_1=gpt-5.4-mini

# Multi-provider gateway
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
AIOS_PROVIDER_ORDER=openrouter,anthropic,openai,deterministic

# OpenRouter model aliases
AIOS_OPENROUTER_SIMPLE_MODEL=anthropic/claude-haiku-4.5
AIOS_OPENROUTER_STANDARD_MODEL=~anthropic/claude-sonnet-latest
AIOS_OPENROUTER_COMPLEX_MODEL=~anthropic/claude-opus-latest

# Direct Anthropic defaults; change if your Anthropic account exposes newer IDs
AIOS_ANTHROPIC_SIMPLE_MODEL=claude-3-5-haiku-20241022
AIOS_ANTHROPIC_STANDARD_MODEL=claude-sonnet-4-20250514
AIOS_ANTHROPIC_COMPLEX_MODEL=claude-opus-4-20250514

# Ollama local provider
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
AIOS_PROVIDER_ORDER=ollama,openrouter,anthropic,openai,deterministic
